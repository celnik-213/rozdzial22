<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp3.NewPage1"
             xmlns:local="clr-namespace:MauiApp3"
             Title="NewPage1">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Wpisz Hasło" 

    FontSize="18" FontAttributes="Bold" />



            <Entry x:Name="PasswordEntry" 

    Placeholder="Min. 8 znaków" 

    IsPassword="True">

                <Entry.Behaviors>

                    <local:PasswordStrengthBehavior 

     StrengthLabel="{x:Reference StrengthLabel}" />

                </Entry.Behaviors>

            </Entry>



            <Label x:Name="StrengthLabel" 

    Text="" 

    FontSize="14" 

    FontAttributes="Bold" 

    Margin="0,10,0,0" />



            <Label Text="Wymogi: Min. 8 znaków, cyfra, wielka litera" 

    FontSize="11" 

    TextColor="Gray" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>