<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp3.NewPage2"
             Title="NewPage2">
    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Rejestracja" 

     FontSize="20" FontAttributes="Bold" 

     HorizontalTextAlignment="Center" />



            <Label Text="Email:" FontAttributes="Bold" />

            <Entry x:Name="EmailEntry" 

     Placeholder="twój@email.com" 

     Keyboard="Email" />



            <Label Text="Hasło:" FontAttributes="Bold" />

            <Entry x:Name="PasswordEntry" 

     Placeholder="Min. 8 znaków, 1 cyfra, 1 wielka litera" 

     IsPassword="True" 
                   TextChanged="UpdatePasswordStrength"/>
            <Label x:Name="StrengthLabel"
                   Text=""/>



            <Label Text="Potwierdzenie hasła:" FontAttributes="Bold" />

            <Entry x:Name="ConfirmPasswordEntry" 

     Placeholder="Powtórz hasło" 

     IsPassword="True" />



            <Label Text="Wiek:" FontAttributes="Bold" />

            <Entry x:Name="AgeEntry" 

     Placeholder="13–120" 

     Keyboard="Numeric" />



            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">

                <CheckBox x:Name="TermsCheckBox" />

                <Label Text="Zgadzam się z regulaminem" 

      VerticalOptions="Center" />

            </HorizontalStackLayout>



            <Button Text="Zarejestruj" 

     Clicked="OnRegisterClicked" 

     Background="#007AFF" 

     TextColor="White" 

     Margin="0,20,0,0" />

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>